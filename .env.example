# ---------------------------------------------------------------------------
# ForgeQA configuration. Copy to .env and edit. Defaults target LM Studio dev.
# ---------------------------------------------------------------------------

# Which local backend to use: "lmstudio" (dev) or "ollama" (docker deploy)
LLM_MODE=lmstudio

# --- LM Studio (dev, on your Mac) ---
# Start LM Studio, load Qwen 7B, click "Start Server".
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5-7b-instruct
LMSTUDIO_API_KEY=lm-studio

# --- Ollama (customer deploy, docker) ---
# Inside docker compose the host is "ollama". Locally it would be localhost.
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_API_KEY=ollama

# --- Optional cloud fallback ---
# Leave blank to stay fully local. If set, ForgeQA falls back here only when
# the local model is unreachable. Nothing is sent to cloud unless local fails.
CLOUD_FALLBACK_ENABLED=false
CLOUD_MODEL=
CLOUD_API_KEY=

# Generation controls
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120
